{
  "name": "yt-downloader-ui",
  "version": "1.0.0",
  "description": "A polished macOS desktop wrapper for searching YouTube and downloading permitted media with yt-dlp.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac --arm64 --x64",
    "dist:arm64": "electron-builder --mac --arm64",
    "dist:x64": "electron-builder --mac --x64",
    "pack": "electron-builder --mac --dir"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.local.ytdownloaderui",
    "productName": "YT Downloader UI",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0"
  }
}
